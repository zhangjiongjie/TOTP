{
  "name": "totp-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "generate:core-icon-registry": "node scripts/generate-core-icon-registry.mjs",
    "generate:harmony-brand-matcher": "node scripts/generate-harmony-brand-matcher.mjs",
    "sync:brand-icons": "npm run generate:core-icon-registry && npm run generate:harmony-brand-matcher && npm run sync:harmony-brand-assets",
    "sync:harmony-brand-assets": "node scripts/sync-harmony-brand-assets.mjs",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build:browser": "npm run build --workspace @totp/browser-extension",
    "test:browser": "npm run test --workspace @totp/browser-extension",
    "typecheck:browser": "npm run typecheck --workspace @totp/browser-extension",
    "test:workspace-smoke": "node -e \"const fs=require('fs');['apps','packages','apps/browser-extension','packages/totp-core','packages/totp-sync'].forEach((p)=>{if(!fs.existsSync(p)) throw new Error(p+' missing')})\""
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
